// prisma/schema.prisma
// Database schema definition for Intense Reload Multi-Branch Stock System using PostgreSQL

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  OWNER
  BRANCH_MANAGER
  STAFF
}

enum StockMovementType {
  STOCK_IN
  // SALE-type StockMovement rows are linked to their parent Sale via StockMovement.saleId (optional FK added in Stage 5).
  // No direct FK existed before Stage 5; the link was previously recoverable by matching branchId + node + createdAt proximity.
  SALE
  ADJUSTMENT
  TRANSFER_OUT
  TRANSFER_IN
  DRILL_DOWN_MIGRATION
}

// Sale status lifecycle: PENDING → APPROVED or REJECTED.
// If StoreSettings.requireSaleApproval is false at creation time, the sale is
// created directly with status APPROVED (see app/api/dashboard/sales/route.ts).
// Stage 6 handles the approval/rejection workflow.
enum SaleStatus {
  PENDING
  APPROVED
  REJECTED
}

// Enum for UserActivityLog audit trail actions.
// APPEND-ONLY — see UserActivityLog model comment.
enum UserActivityAction {
  ACCOUNT_CREATED
  ROLE_CHANGED
  BRANCH_ASSIGNED
  BRANCH_UNASSIGNED
  ACCOUNT_DEACTIVATED
  ACCOUNT_REACTIVATED
  PASSWORD_CHANGED
}

// Stage 6: Notification types surfaced in the in-app notification bell.
// LOW_STOCK is forward-referenced for Stage 10 so this enum requires no future migration.
enum NotificationType {
  SALE_PENDING_APPROVAL
  SALE_REJECTED
  SALE_EDITED
  LOW_STOCK
}

model User {
  id                 String                 @id @default(cuid())
  name               String
  email              String                 @unique
  emailVerified      DateTime?
  password           String                 // hashed
  image              String?
  role               UserRole               @default(STAFF)
  mustChangePassword Boolean                @default(false)
  isActive           Boolean                @default(true)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  accounts              Account[]
  sessions              Session[]
  branchAssignments     UserBranchAssignment[]
  // Stage 5: named relations required because User has two FK references on Sale.
  loggedSales           Sale[]                 @relation("SaleLoggedBy")
  reviewedSales         Sale[]                 @relation("SaleReviewedBy")
  stockMovements        StockMovement[]
  activityLogsAsActor   UserActivityLog[]      @relation("ActivityLogActor")
  activityLogsAsTarget  UserActivityLog[]      @relation("ActivityLogTarget")
  // Stage 6: in-app notifications for OWNER/BRANCH_MANAGER review events.
  notifications         Notification[]
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Branch {
  id                String                 @id @default(cuid())
  name              String
  town              String
  address           String?                // Street-level detail beyond town
  contactNumber     String?
  isActive          Boolean                @default(true)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  inventoryRecords  Inventory[]
  stockMovements    StockMovement[]
  userAssignments   UserBranchAssignment[]
  sales             Sale[]
}

model UserBranchAssignment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, branchId])
}

// APPEND-ONLY. No PUT/PATCH/DELETE route will ever be created for this model.
// This is a deliberate security control (OWASP A09: Security Logging and Monitoring).
// Do not add update or delete endpoints for UserActivityLog in any future stage.
model UserActivityLog {
  id           String             @id @default(cuid())
  actorId      String
  actor        User               @relation("ActivityLogActor", fields: [actorId], references: [id])
  targetUserId String?
  targetUser   User?              @relation("ActivityLogTarget", fields: [targetUserId], references: [id])
  action       UserActivityAction
  details      Json?              // e.g. { "previousRole": "STAFF", "newRole": "BRANCH_MANAGER" }
  createdAt    DateTime           @default(now())
}

model StoreSettings {
  id                           String   @id @default(cuid())
  storeName                    String   @default("Intense Reload")
  storeTagline                 String?
  logoUrl                      String?
  accentColor                  String   @default("#1D4ED8")
  enablePOS                    Boolean  @default(false)
  enableBarcodeScanning        Boolean  @default(false)
  enableStockValueTracking     Boolean  @default(false)
  requireSaleApproval          Boolean  @default(true)
  enableDetailedSaleBreakdown  Boolean  @default(false)
  whatsappNumber               String?
  returnPolicy                 String?  @db.Text
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
}

model Category {
  id             String          @id @default(cuid())
  name           String
  slug           String          @unique
  description    String?         @db.Text
  imageUrl       String?
  parentId       String?
  parent         Category?       @relation("CategoryToCategory", fields: [parentId], references: [id], onDelete: Restrict)
  children       Category[]      @relation("CategoryToCategory")
  isStockBearing Boolean         @default(false)
  sortOrder      Int             @default(0)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  products       Product[]
  inventoryRecords Inventory[]
  stockMovements   StockMovement[]
  saleItems        SaleItem[]
}

model Product {
  id             String           @id @default(cuid())
  name           String
  slug           String           @unique
  description    String?          @db.Text
  brand          String?
  tags           String[]
  images         String[]
  categoryId     String
  category       Category         @relation(fields: [categoryId], references: [id])
  isStockBearing Boolean          @default(false)
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  variants       ProductVariant[]
  inventoryRecords Inventory[]
  stockMovements   StockMovement[]
  saleItems        SaleItem[]
}

model ProductVariant {
  id           String          @id @default(cuid())
  productId    String
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku          String?         @unique
  size         String?
  colour       String?
  brand        String?         // overrides product brand if set
  costPrice    Decimal?        @db.Decimal(10, 2)
  sellingPrice Decimal?        @db.Decimal(10, 2)
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  inventoryRecords Inventory[]
  stockMovements   StockMovement[]
  saleItems        SaleItem[]
}

// Polymorphic Inventory model.
// Constraint: exactly one of categoryId, productId, or productVariantId must be non-null.
// This is enforced at the database level by unique indexes preventing duplicates for the same node+branch,
// and at the application layer via Zod validations.
model Inventory {
  id                  String          @id @default(cuid())
  branchId            String
  branch              Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  categoryId          String?
  category            Category?       @relation(fields: [categoryId], references: [id])
  productId           String?
  product             Product?        @relation(fields: [productId], references: [id])
  productVariantId    String?
  productVariant      ProductVariant? @relation(fields: [productVariantId], references: [id])
  quantity            Int             @default(0)
  lowStockThreshold   Int             @default(5)
  isReferenceSnapshot Boolean         @default(false)
  snapshotLabel       String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@unique([branchId, categoryId])
  @@unique([branchId, productId])
  @@unique([branchId, productVariantId])
}

// APPEND-ONLY Stock Movement audit trail.
// No UPDATE or DELETE operations will ever be implemented against this model.
// (OWASP A09: Security Logging and Monitoring)
// Stage 5: saleId added as optional FK (onDelete: SetNull) so SALE-type movements
// are directly traceable to their parent Sale. Sale rows should never be deleted,
// but SetNull is specified defensively — StockMovement survival is non-negotiable.
model StockMovement {
  id               String            @id @default(cuid())
  branchId         String
  branch           Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  categoryId       String?
  category         Category?         @relation(fields: [categoryId], references: [id])
  productId        String?
  product          Product?          @relation(fields: [productId], references: [id])
  productVariantId String?
  productVariant   ProductVariant?   @relation(fields: [productVariantId], references: [id])
  type             StockMovementType
  quantityBefore   Int
  quantityAfter    Int
  quantityDelta    Int
  note             String?
  // Optional link to a Sale. Set for SALE-type movements created during POST /api/dashboard/sales.
  // onDelete: SetNull — StockMovement rows must survive even if Sale record is somehow removed.
  saleId           String?
  sale             Sale?             @relation(fields: [saleId], references: [id], onDelete: SetNull)
  performedById    String
  performedBy      User              @relation(fields: [performedById], references: [id])
  createdAt        DateTime          @default(now())
}

// Sale — records a stock-out transaction logged at the shop counter.
// APPEND-ONLY in spirit: no DELETE route will ever exist for Sale.
// Status lifecycle: PENDING → APPROVED | REJECTED (Stage 6 approval workflow).
// If StoreSettings.requireSaleApproval is false, sale is created as APPROVED immediately.
// Inventory.quantity is decremented at creation time regardless of status — the audit
// trail reflects the immediate state change; Stage 6 ADJUSTMENT StockMovements handle reversals.
model Sale {
  id               String          @id @default(cuid())
  branchId         String
  branch           Branch          @relation(fields: [branchId], references: [id])
  status           SaleStatus      @default(PENDING)
  loggedById       String
  // Named relation required: User has two FK references to Sale (loggedBy + reviewedBy).
  loggedBy         User            @relation("SaleLoggedBy", fields: [loggedById], references: [id])
  // Set in Stage 6 when an OWNER or BRANCH_MANAGER approves or rejects the sale.
  reviewedById     String?
  reviewedBy       User?           @relation("SaleReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt       DateTime?
  // Max 255 chars — set by the reviewer in Stage 6 when rejecting a sale.
  rejectionReason  String?         @db.VarChar(255)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  items            SaleItem[]
  stockMovements   StockMovement[]
  // Stage 6: notifications triggered by this sale (e.g. rejection notices to the logging staff member).
  notifications    Notification[]
}

// SaleItem — one line item within a Sale.
// Polymorphic: exactly one of categoryId, productId, productVariantId must be non-null.
// This invariant is enforced at the application layer by assertExactlyOneStockParent
// (lib/validations/inventory.ts) — now shared by three models:
//   Inventory, StockMovement (indirectly via Sale context), and SaleItem.
// No database-level CHECK constraint is available via Prisma; unique indexes on
// Inventory prevent node+branch duplicates. SaleItem has no such uniqueness need.
model SaleItem {
  id               String          @id @default(cuid())
  saleId           String
  sale             Sale            @relation(fields: [saleId], references: [id], onDelete: Cascade)
  // Polymorphic node reference — exactly one must be set (enforced at app layer).
  categoryId       String?
  category         Category?       @relation(fields: [categoryId], references: [id])
  productId        String?
  product          Product?        @relation(fields: [productId], references: [id])
  productVariantId String?
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])
  // Positive integer — max 1000 enforced in lib/validations/sale.ts, not here.
  quantity         Int
  createdAt        DateTime        @default(now())
}

// Stage 6: In-app notification record for a single recipient.
// APPEND-ONLY in spirit — no DELETE or UPDATE routes are created for this model.
// Composite index on (userId, isRead, createdAt) enables efficient:
//   - unread count queries  (userId + isRead=false)
//   - "recent notifications" list  (userId + ORDER BY createdAt DESC)
model Notification {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          NotificationType
  // max 150 chars — enforced in lib/notifications.ts createNotification params validation
  title         String           @db.VarChar(150)
  // max 500 chars — enforced in lib/notifications.ts createNotification params validation
  body          String           @db.VarChar(500)
  // Optional deep-link URL rendered in the notification bell dropdown.
  linkUrl       String?
  isRead        Boolean          @default(false)
  // Optional FK to the Sale that triggered this notification.
  // onDelete: SetNull — notifications must survive even if a Sale row is removed.
  relatedSaleId String?
  relatedSale   Sale?            @relation(fields: [relatedSaleId], references: [id], onDelete: SetNull)
  createdAt     DateTime         @default(now())

  @@index([userId, isRead, createdAt])
}
